# Copy this file to .env and adjust as needed.

# --- Database ---
# PostgreSQL (recommended for the "real" local run). Create the DB first, e.g.:
#   createdb safeconnect
# Then set:
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/safeconnect

# If you'd rather skip installing Postgres for a quick test, comment the line
# above out (or delete it). The app will automatically fall back to a local
# SQLite file (./safeconnect.db) with zero setup.

# --- Auth ---
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- CORS ---
# Comma-separated list of allowed origins, or * for all (fine for local dev).
CORS_ALLOW_ORIGINS=*
